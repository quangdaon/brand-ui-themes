  "tokenColors": [
    {
      "name": "Comment",
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": {
        "foreground": "#3e4d6a",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Doc comment",
      "scope": [
        "comment.block.documentation",
        "comment.block.javadoc",
        "string.quoted.docstring"
      ],
      "settings": {
        "foreground": "#5a6d8a",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Keyword",
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.new",
        "keyword.operator.expression",
        "keyword.operator.logical",
        "storage",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#c4325a"
      }
    },
    {
      "name": "Preprocessor",
      "scope": [
        "keyword.control.directive",
        "keyword.preprocessor",
        "meta.preprocessor"
      ],
      "settings": {
        "foreground": "#c4325a"
      }
    },
    {
      "name": "Type",
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.name.namespace",
        "support.type",
        "support.class",
        "entity.other.inherited-class"
      ],
      "settings": {
        "foreground": "#FFA630"
      }
    },
    {
      "name": "Enum",
      "scope": [
        "entity.name.type.enum",
        "entity.name.type.enum.member",
        "variable.other.enummember"
      ],
      "settings": {
        "foreground": "#FFA630"
      }
    },
    {
      "name": "Type parameter / generic",
      "scope": [
        "entity.name.type.parameter",
        "meta.type.parameters entity.name.type"
      ],
      "settings": {
        "foreground": "#FFA630"
      }
    },
    {
      "name": "Interface",
      "scope": ["entity.name.type.interface"],
      "settings": {
        "foreground": "#FFA630"
      }
    },
    {
      "name": "Primitive type annotations",
      "scope": [
        "support.type.primitive",
        "support.type.builtin",
        "keyword.type"
      ],
      "settings": {
        "foreground": "#FFA630"
      }
    },
    {
      "name": "Function",
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call entity.name.function"
      ],
      "settings": {
        "foreground": "#4a7ec4"
      }
    },
    {
      "name": "Constructor",
      "scope": [
        "entity.name.function.constructor",
        "meta.function-call.constructor"
      ],
      "settings": {
        "foreground": "#4a7ec4"
      }
    },
    {
      "name": "String",
      "scope": [
        "string",
        "string.quoted",
        "string.template"
      ],
      "settings": {
        "foreground": "#5da628"
      }
    },
    {
      "name": "String escape",
      "scope": [
        "constant.character.escape",
        "string.escape"
      ],
      "settings": {
        "foreground": "#46a8a0"
      }
    },
    {
      "name": "Template expression",
      "scope": [
        "punctuation.definition.template-expression.begin",
        "punctuation.definition.template-expression.end",
        "punctuation.section.embedded"
      ],
      "settings": {
        "foreground": "#46a8a0"
      }
    },
    {
      "name": "Regex",
      "scope": [
        "string.regexp",
        "constant.other.character-class.regexp",
        "keyword.operator.quantifier.regexp"
      ],
      "settings": {
        "foreground": "#5da628"
      }
    },
    {
      "name": "Number / Boolean / Constant",
      "scope": [
        "constant.numeric",
        "constant.language",
        "constant.language.boolean",
        "constant.language.null",
        "constant.language.undefined",
        "support.constant",
        "constant.other"
      ],
      "settings": {
        "foreground": "#5da628"
      }
    },
    {
      "name": "Variable",
      "scope": [
        "variable",
        "variable.other",
        "variable.parameter"
      ],
      "settings": {
        "foreground": "#d4d6dd"
      }
    },
    {
      "name": "Variable special (this, self)",
      "scope": [
        "variable.language",
        "variable.language.this",
        "variable.language.self",
        "variable.language.super"
      ],
      "settings": {
        "foreground": "#5da628"
      }
    },
    {
      "name": "Property",
      "scope": [
        "variable.other.property",
        "variable.other.object.property",
        "support.variable.property",
        "meta.object-literal.key"
      ],
      "settings": {
        "foreground": "#c4325a"
      }
    },
    {
      "name": "Operator",
      "scope": [
        "keyword.operator",
        "keyword.operator.assignment",
        "keyword.operator.comparison",
        "keyword.operator.arithmetic",
        "keyword.operator.type",
        "keyword.operator.ternary"
      ],
      "settings": {
        "foreground": "#46a8a0"
      }
    },
    {
      "name": "Punctuation",
      "scope": [
        "punctuation",
        "punctuation.definition",
        "punctuation.separator",
        "punctuation.terminator",
        "meta.brace"
      ],
      "settings": {
        "foreground": "#b0b5c4"
      }
    },
    {
      "name": "Tag (HTML/JSX/Svelte)",
      "scope": [
        "entity.name.tag",
        "support.class.component"
      ],
      "settings": {
        "foreground": "#c4325a"
      }
    },
    {
      "name": "Tag attribute",
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#FFA630"
      }
    },
    {
      "name": "Decorator / Annotation",
      "scope": [
        "meta.decorator",
        "meta.decorator entity.name.function",
        "meta.annotation"
      ],
      "settings": {
        "foreground": "#FFA630"
      }
    },
    {
      "name": "CSS selector",
      "scope": [
        "entity.other.attribute-name.class.css",
        "entity.other.attribute-name.id.css",
        "entity.name.tag.css"
      ],
      "settings": {
        "foreground": "#FFA630"
      }
    },
    {
      "name": "CSS property",
      "scope": [
        "support.type.property-name.css",
        "support.type.vendored.property-name.css"
      ],
      "settings": {
        "foreground": "#c4325a"
      }
    },
    {
      "name": "CSS value / unit",
      "scope": [
        "support.constant.property-value.css",
        "constant.numeric.css",
        "keyword.other.unit.css"
      ],
      "settings": {
        "foreground": "#5da628"
      }
    },
    {
      "name": "CSS pseudo",
      "scope": [
        "entity.other.attribute-name.pseudo-class.css",
        "entity.other.attribute-name.pseudo-element.css"
      ],
      "settings": {
        "foreground": "#4a7ec4"
      }
    },
    {
      "name": "Link text (Markdown)",
      "scope": [
        "string.other.link.title.markdown",
        "string.other.link.description.markdown"
      ],
      "settings": {
        "foreground": "#4a7ec4"
      }
    },
    {
      "name": "Link URI",
      "scope": [
        "markup.underline.link",
        "markup.underline.link.markdown"
      ],
      "settings": {
        "foreground": "#46a8a0"
      }
    },
    {
      "name": "Markup heading",
      "scope": [
        "markup.heading",
        "entity.name.section"
      ],
      "settings": {
        "foreground": "#FFA630",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markup bold",
      "scope": ["markup.bold"],
      "settings": {
        "foreground": "#FFA630",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markup italic",
      "scope": ["markup.italic"],
      "settings": {
        "foreground": "#c4325a",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Markup code / inline",
      "scope": [
        "markup.inline.raw",
        "markup.fenced_code.block",
        "markup.raw.block"
      ],
      "settings": {
        "foreground": "#5da628"
      }
    },
    {
      "name": "Markup list marker",
      "scope": ["punctuation.definition.list.begin.markdown"],
      "settings": {
        "foreground": "#c4325a"
      }
    },
    {
      "name": "Diff inserted",
      "scope": ["markup.inserted"],
      "settings": {
        "foreground": "#4a8a1e"
      }
    },
    {
      "name": "Diff deleted",
      "scope": ["markup.deleted"],
      "settings": {
        "foreground": "#c4325a"
      }
    },
    {
      "name": "Diff changed",
      "scope": ["markup.changed"],
      "settings": {
        "foreground": "#FFA630"
      }
    },
    {
      "name": "JSON property",
      "scope": ["support.type.property-name.json"],
      "settings": {
        "foreground": "#c4325a"
      }
    },
    {
      "name": "YAML key",
      "scope": ["entity.name.tag.yaml"],
      "settings": {
        "foreground": "#c4325a"
      }
    },
    {
      "name": "TOML key",
      "scope": ["keyword.key.toml", "support.type.property-name.toml"],
      "settings": {
        "foreground": "#c4325a"
      }
    },
    {
      "name": "Namespace",
      "scope": ["entity.name.namespace", "entity.name.scope-resolution"],
      "settings": {
        "foreground": "#d4d6dd"
      }
    },
    {
      "name": "C# - Attribute",
      "scope": ["meta.attribute.csharp entity.name.type"],
      "settings": {
        "foreground": "#FFA630"
      }
    },
    {
      "name": "Go - Package name",
      "scope": ["entity.name.package.go"],
      "settings": {
        "foreground": "#d4d6dd"
      }
    }
  ],
  "semanticHighlighting": true,
  "semanticTokenColors": {
    "type": "#FFA630",
    "class": "#FFA630",
    "enum": "#FFA630",
    "interface": "#FFA630",
    "struct": "#FFA630",
    "typeParameter": "#FFA630",
    "parameter": "#d4d6dd",
    "variable": "#d4d6dd",
    "variable.readonly": "#5da628",
    "property": "#c4325a",
    "enumMember": "#FFA630",
    "function": "#4a7ec4",
    "method": "#4a7ec4",
    "macro": "#c4325a",
    "keyword": "#c4325a",
    "comment": { "foreground": "#3e4d6a", "fontStyle": "italic" },
